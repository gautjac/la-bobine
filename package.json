{
  "name": "la-bobine",
  "version": "1.0.0",
  "private": true,
  "description": "Studio matinal — poème + narration → reel Instagram vertical (timeline éditable, images génératives via Fal, texte synchronisé à l'audio).",
  "type": "module",
  "scripts": {
    "studio": "concurrently -k -n serveur,app -c yellow,cyan \"npm run server\" \"npm run app\"",
    "app": "vite",
    "server": "node --env-file=.env --import tsx server/index.ts",
    "web": "vite build && npm run server",
    "render": "remotion render Bobine out/draft.mp4 --crf 18",
    "remotion:studio": "remotion studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@remotion/cli": "4.0.486",
    "@remotion/google-fonts": "4.0.486",
    "@remotion/player": "4.0.486",
    "@remotion/zod-types": "4.0.486",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.486",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.3",
    "vitest": "^3.2.4"
  }
}
